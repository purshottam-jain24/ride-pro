# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit your real keys.
#
# Expo SDK 54 reads any variable prefixed with EXPO_PUBLIC_ into process.env at build time.
# These end up in the client bundle, so only put values that are safe to expose to end users
# (Firebase web config is designed for this — backstop with Firestore Security Rules).

# ---- Firebase ----
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- Google Sign-In (development build only; ignored in Expo Go) ----
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
